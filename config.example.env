# Copy to .env and adjust. Used by the container entrypoint / real-mode runner.
REPO_URL=https://github.com/bilalurrahman/HattanMedicalHistory.git
REPO_PATH=C:\path\to\HattanMedicalHistory
GIT_BRANCH=quality
LOOP_PR_BASE=quality
LOOP_BRANCH_PREFIX=glm_quality
LOOP_SLN=backend/HattanHealthTracker.sln
WARN_STEP=10
MAX_ITERS=5
LOOP_MODEL=glm-5.2:cloud
OLLAMA_HOST=http://localhost:11434
UI_PORT=8787
# GH_TOKEN=ghp_xxx   # fine-grained PAT with repo + PR scope (real/--open-pr only)
